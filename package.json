{
  "name": "discord-bots",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "oxlint",
    "lint:eslint": "eslint .",
    "lint:all": "npm run lint && npm run lint:eslint",
    "test": "vitest --coverage",
    "test:run": "turbo test:run",
    "prepare": "turbo build --filter=./packages/*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-oxlint": "^1.59.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "turbo": "^2.9.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
