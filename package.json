{
  "name": "discord-bots",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "oxlint",
    "test": "vitest",
    "test:run": "turbo test:run",
    "prepare": "turbo build --filter=./packages/*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "turbo": "^2.9.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
