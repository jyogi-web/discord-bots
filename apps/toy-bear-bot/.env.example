# Discord Bot トークン（必須）
DISCORD_TOKEN=your_discord_token_here

# Bot の Application ID（必須）: Discord Developer Portal → アプリ選択 → Application ID
CLIENT_ID=your_client_id_here

# kawaii機能: リアクションで転送するチャンネルID（必須）
FORWARD_CHANNEL_ID=your_channel_id_here

# kawaii機能: 監視する絵文字名（省略時: kawaii）
TARGET_EMOJI_NAME=kawaii

# Feature Flags（省略時はすべて true）
FEATURE_KAWAII=true
FEATURE_EYES_LIPS=true
FEATURE_GACHA=true

# Axiom ログ基盤（必須）
# https://axiom.co/ でアカウント作成 → Dataset と API Token を発行
AXIOM_TOKEN=your_axiom_token_here
AXIOM_DATASET=your_axiom_dataset_name_here

# エラー通知 Discord Webhook（省略可）
# 設定するとエラーログを Discord に即時通知する
DISCORD_ERROR_WEBHOOK_URL=

# 共通設定
LOG_LEVEL=info
NODE_ENV=production
